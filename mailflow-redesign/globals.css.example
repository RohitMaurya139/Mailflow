/* ============================================================================
 * mailflow/apps/web/app/globals.css — REPLACEMENT TOKEN BLOCK
 *
 * This is the new token system for the Mailflow redesign. Replace the entire
 * `@theme` block (Tailwind v4) and the `:root` / `.dark` CSS variable blocks
 * in your existing globals.css with the contents of this file.
 *
 * shadcn variables (--background, --foreground, --primary, etc.) are mapped
 * onto the new palette so every shadcn primitive picks up the redesign with
 * zero code changes inside components/ui/*.
 * ========================================================================== */

@import "tailwindcss";

@theme {
  /* Type */
  --font-sans: var(--font-geist, "Geist"), ui-sans-serif, system-ui, -apple-system, sans-serif;
  --font-serif: var(--font-instrument, "Instrument Serif"), ui-serif, Georgia, serif;
  --font-mono: var(--font-geist-mono, "Geist Mono"), ui-monospace, monospace;

  /* Radius */
  --radius-sm: 6px;
  --radius: 8px;
  --radius-md: 8px;
  --radius-lg: 12px;
  --radius-xl: 16px;

  /* Brand color tokens (raw) */
  --color-canvas: #F4F1E9;
  --color-surface: #FBF9F2;
  --color-surface-2: #EFEBDE;
  --color-ink: #1B1814;
  --color-ink-2: #3A332A;
  --color-muted: #6E665B;
  --color-muted-2: #9A9082;
  --color-hairline: #E2DBCB;
  --color-hairline-strong: #D2C9B6;

  --color-clay: oklch(0.62 0.13 45);          /* ≈ #B65A3E */
  --color-clay-ink: #7A3520;
  --color-clay-soft: #EBD9CF;

  --color-sage: #5C8A6E;
  --color-sage-soft: #DCE6DE;
  --color-amber: #C28B2A;
  --color-amber-soft: #F1E6C8;
  --color-rose: #B0496B;
  --color-rose-soft: #F0D9DF;
}

/* ----------------------------------------------------------------------------
 * shadcn token aliases (light) — map our brand tokens onto the names that the
 * `new-york` style + every primitive in components/ui/* references.
 * -------------------------------------------------------------------------- */

:root {
  --background: 244 241 233;            /* canvas */
  --foreground: 27 24 20;               /* ink */

  --card: 251 249 242;                  /* surface */
  --card-foreground: 27 24 20;

  --popover: 251 249 242;
  --popover-foreground: 27 24 20;

  --primary: 27 24 20;                  /* ink button bg */
  --primary-foreground: 244 241 233;    /* canvas text */

  --secondary: 239 235 222;             /* surface-2 */
  --secondary-foreground: 27 24 20;

  --muted: 239 235 222;
  --muted-foreground: 110 102 91;

  --accent: 235 217 207;                /* clay-soft */
  --accent-foreground: 122 53 32;       /* clay-ink */

  --destructive: 176 73 107;            /* rose */
  --destructive-foreground: 251 249 242;

  --success: 92 138 110;                /* sage */
  --warning: 194 139 42;                /* amber */
  --info: 27 24 20;                     /* lean into ink for neutral info */

  --border: 226 219 203;                /* hairline */
  --input: 226 219 203;
  --ring: 182 90 62;                    /* clay focus ring */

  --radius: 0.5rem;                     /* 8px shadcn default */

  /* Sidebar */
  --sidebar: 244 241 233;
  --sidebar-foreground: 58 51 42;
  --sidebar-primary: 182 90 62;
  --sidebar-primary-foreground: 255 255 255;
  --sidebar-accent: 251 249 242;
  --sidebar-accent-foreground: 27 24 20;
  --sidebar-border: 226 219 203;
  --sidebar-ring: 182 90 62;

  /* Charts (use clay/sage/amber/rose/ink as the 5 series) */
  --chart-1: 182 90 62;                 /* clay */
  --chart-2: 92 138 110;                /* sage */
  --chart-3: 194 139 42;                /* amber */
  --chart-4: 176 73 107;                /* rose */
  --chart-5: 27 24 20;                  /* ink */
}

/* ----------------------------------------------------------------------------
 * Dark mode — a deeper, warmer dark. Same palette logic: ink becomes canvas,
 * everything else inverts toward the warm scale (not slate).
 * -------------------------------------------------------------------------- */

.dark {
  --background: 24 21 18;               /* near-black, warm */
  --foreground: 244 241 233;            /* warm cream text */

  --card: 32 28 24;
  --card-foreground: 244 241 233;

  --popover: 32 28 24;
  --popover-foreground: 244 241 233;

  --primary: 244 241 233;               /* invert: cream button */
  --primary-foreground: 24 21 18;

  --secondary: 44 39 33;
  --secondary-foreground: 244 241 233;

  --muted: 44 39 33;
  --muted-foreground: 154 144 130;

  --accent: 74 36 22;                   /* dark clay */
  --accent-foreground: 235 217 207;

  --destructive: 176 73 107;
  --destructive-foreground: 244 241 233;

  --border: 56 49 41;
  --input: 56 49 41;
  --ring: 217 119 87;                   /* lifted clay for dark contrast */

  --sidebar: 20 18 15;
  --sidebar-foreground: 219 211 195;
  --sidebar-primary: 217 119 87;
  --sidebar-primary-foreground: 24 21 18;
  --sidebar-accent: 32 28 24;
  --sidebar-accent-foreground: 244 241 233;
  --sidebar-border: 56 49 41;
  --sidebar-ring: 217 119 87;
}

/* ----------------------------------------------------------------------------
 * Base
 * -------------------------------------------------------------------------- */

@layer base {
  * { @apply border-border; }
  html { font-feature-settings: "ss01", "cv11"; -webkit-font-smoothing: antialiased; }
  body {
    @apply bg-background text-foreground;
    font-family: var(--font-sans);
    font-feature-settings: "ss01", "cv11";
  }
  /* Display headlines default to serif; opt-in per element */
  .font-display, .display, h1.display { font-family: var(--font-serif); letter-spacing: -0.02em; font-weight: 400; }
  /* Italic emphasis inside serif headlines uses clay */
  .display em, h1.display em, .font-display em { color: rgb(var(--ring)); font-style: italic; }
  /* Selection */
  ::selection { background: rgb(var(--accent)); color: rgb(var(--accent-foreground)); }
}

/* ----------------------------------------------------------------------------
 * Component utilities used across the redesign. Keep these aligned with the
 * `.mf-*` classes in preview/styles.css — they're the canonical source.
 * -------------------------------------------------------------------------- */

@layer components {
  .mono { font-family: var(--font-mono); }
  .serif { font-family: var(--font-serif); }

  /* Mono label used above stats / column heads */
  .label-mono {
    font-family: var(--font-mono);
    font-size: 10.5px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgb(var(--muted-foreground));
    font-weight: 500;
  }

  /* Subtle hairline divider */
  .hairline { border-color: rgb(var(--border)); }

  /* Status dot prefix used inside badges */
  .badge-dot::before {
    content: "";
    display: inline-block;
    width: 6px; height: 6px; border-radius: 999px;
    background: currentColor;
    margin-right: 6px;
    vertical-align: 1px;
  }
}
